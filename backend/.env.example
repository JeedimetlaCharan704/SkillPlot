NODE_ENV=development
PORT=5000

# MongoDB — replace with your connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/skillpilot?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# GitHub API (optional — for higher rate limit with live data)
GITHUB_TOKEN=

# Google OAuth (optional — for Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis (optional — for background jobs and caching)
REDIS_URL=

# CORS
CORS_ORIGIN=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
